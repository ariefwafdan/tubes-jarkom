import socket
import threading

HOST = '0.0.0.0'
TCP_PORT = 8000
UDP_PORT = 9000

# UDP SERVER (QoS)
def udp_server():
    udp_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    udp_socket.bind((HOST, UDP_PORT))

    print("UDP Server berjalan di port 9000...")

    while True:
        data, addr = udp_socket.recvfrom(1024)
        print(f"[UDP] dari {addr}: {data.decode()}")

        # Echo balik data
        udp_socket.sendto(data, addr)

threading.Thread(target=udp_server, daemon=True).start()



# TCP HTTP SERVER
tcp_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
tcp_socket.bind((HOST, TCP_PORT))
tcp_socket.listen(5)

print(f"Web Server berjalan di port {TCP_PORT}...")

while True:
    client_socket, client_address = tcp_socket.accept()
    print(f"Koneksi dari {client_address}")

    request = client_socket.recv(1024).decode()
    print("Request:\n", request)

    try:
        # Parsing request
        request_line = request.split('\n')[0]
        method, path, version = request_line.split()

        if path == "/":
            path = "/index.html"

        file_path = path[1:]

        # Buka file 
        with open(file_path, 'rb') as file:
            content = file.read()

        header = "HTTP/1.1 200 OK\r\n"
        header += "Content-Type: text/html\r\n"
        header += f"Content-Length: {len(content)}\r\n"
        header += "\r\n"

        response = header.encode() + content

        print(f"200 OK - {file_path}")

    except FileNotFoundError:
        response = b"HTTP/1.1 404 Not Found\r\n\r\n<h1>404 Not Found</h1>"
        print(f"404 Not Found - {file_path}")

    except Exception as e:
        response = b"HTTP/1.1 500 Internal Server Error\r\n\r\n<h1>500 Error</h1>"
        print("Error:", e)

    client_socket.sendall(response)
    client_socket.close()
